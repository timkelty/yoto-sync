# Yoto API OAuth2 client ID (required)
YOTO_CLIENT_ID=

# Server port (default: 3000)
PORT=3000

# Directory for state store and token persistence (default: ./data)
DATA_DIR=./data

# Log level: fatal, error, warn, info, debug, trace (default: info)
LOG_LEVEL=info

# Plex server URL (optional, required for Plex adapter)
# PLEX_URL=http://192.168.1.100:32400

# Plex authentication token (optional, required for Plex adapter)
# PLEX_TOKEN=

# Path to sync config file for playlist-to-card mapping (optional)
# SYNC_CONFIG_PATH=./sync-config.json

# Polling interval in seconds for auto-sync (default: 300 = 5 minutes, minimum: 10)
# POLL_INTERVAL_SECONDS=300

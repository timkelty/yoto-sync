{
  "name": "yoto-sync",
  "version": "0.1.0",
  "description": "Sync playlist sources into Yoto Make-Your-Own cards",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenvx run -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@lukehagar/plexjs": "^0.43.0",
    "@yotoplay/yoto-sdk": "^1.2.4",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.40.0",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.0",
    "msw": "^2.7.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.1.0"
  }
}
